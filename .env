# Файл переменных окружения для проекта
# Скопируйте этот файл в .env и заполните своими значениями

# База данных PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=coding_platform
DB_USER=admin
DB_PASSWORD=Sserapheam17*

# Flask секретный ключ (ВАЖНО: сгенерируйте свой!)
# Для генерации запустите: python -c "import secrets, string; print(''.join(secrets.choice(string.ascii_letters + string.digits + '!@#$%^&*') for _ in range(50)))"
FLASK_SECRET=gtc0Yi4G7vsGuQIjyLKHJkxjHA0G2!YcmSdzYiZIeSxcCy#YV4

# Использовать Docker для выполнения кода (true/false)
# Если true, код будет выполняться в изолированном Docker контейнере
# Если false или Docker недоступен, используется обычный subprocess режим
USE_DOCKER=true

# Автоматически удалять контейнеры после выполнения (true/false)
# Если false, контейнеры останутся для отладки (можно посмотреть через docker ps -a)
# Для production рекомендуется true (безопасность и экономия места)
DOCKER_AUTO_REMOVE=true

# Размер пула контейнеров для переиспользования (по умолчанию 5)
# Больше контейнеров = быстрее при параллельных запросах, но больше использование памяти
# При использовании пула контейнеры создаются один раз и переиспользуются для ускорения
# Рекомендации:
#   - CPU < 4 ядер: 3-4 контейнера
#   - CPU 4-8 ядер: 5-7 контейнеров
#   - CPU > 8 ядер: 8-12 контейнеров
DOCKER_POOL_SIZE=5

# Прогрев контейнеров при создании (true/false, по умолчанию true)
# Если true, контейнеры прогреваются простым кодом для инициализации Python
# Преимущества: все выполнения быстрые, включая первое
# Недостатки: создание пула занимает больше времени (~1-2 секунды)
DOCKER_WARMUP=true

DOCKER_HOST=tcp://host.docker.internal:2375