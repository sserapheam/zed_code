# Скопируйте в .env и заполните своими значениями

DB_HOST=localhost
DB_PORT=5432
DB_NAME=coding_platform
DB_USER=admin
DB_PASSWORD=change-me

FLASK_SECRET=generate-a-long-random-secret
REQUIRE_FLASK_SECRET=true
FLASK_ENV=production

USE_DOCKER=true
DOCKER_AUTO_REMOVE=true
DOCKER_USE_POOL=false
DOCKER_POOL_SIZE=5
DOCKER_WARMUP=true

# --- Почта для сброса пароля (Яндекс) ---
# 1) Создайте ящик (например noreply@yandex.ru или на своём домене)
# 2) В аккаунте Яндекса: Безопасность → Пароли приложений → создайте пароль для «Почта»
# 3) Вставьте ниже логин (полный email) и пароль приложения (не обычный пароль!)
#
# Рекомендуемый вариант — SSL 465:
MAIL_SERVER=smtp.yandex.ru
MAIL_PORT=465
MAIL_USERNAME=your-bot@yandex.ru
MAIL_PASSWORD=app-password-from-yandex
MAIL_FROM=your-bot@yandex.ru
MAIL_USE_SSL=true
MAIL_USE_TLS=false
#
# Альтернатива STARTTLS 587:
# MAIL_PORT=587
# MAIL_USE_SSL=false
# MAIL_USE_TLS=true

# Только для локальной отладки без SMTP (на проде оставьте false)
ALLOW_DEV_RESET_LINK=false
